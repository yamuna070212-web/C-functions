#include <stdio.h>

int isPalindrome(int n);

int main()
{
    int n;

    printf("Enter Number: ");
    scanf("%d", &n);

    if(isPalindrome(n))
        printf("Palindrome Number");
    else
        printf("Not a Palindrome Number");

    return 0;
}

int isPalindrome(int n)
{
    int temp = n, rem, rev = 0;

    while(n != 0)
    {
        rem = n % 10;
        rev = rev * 10 + rem;
        n /= 10;
    }

    return (temp == rev);
}

#include <stdio.h>

int lcm(int a, int b);

int main()
{
    int a, b;

    printf("Enter Two Numbers: ");
    scanf("%d%d", &a, &b);

    printf("LCM = %d", lcm(a, b));

    return 0;
}

int lcm(int a, int b)
{
    int max = (a > b) ? a : b;

    while(1)
    {
        if(max % a == 0 && max % b == 0)
            return max;

        max++;
    }
}
Sample Output
Enter Two Numbers: 6 8
LCM = 24

#include <stdio.h>

int largest(int arr[], int n);

int main()
{
    int arr[5], i;

    printf("Enter 5 Numbers:\n");

    for(i = 0; i < 5; i++)
        scanf("%d", &arr[i]);

    printf("Largest = %d", largest(arr, 5));

    return 0;
}

int largest(int arr[], int n)
{
    int i, max = arr[0];

    for(i = 1; i < n; i++)
    {
        if(arr[i] > max)
            max = arr[i];
    }

    return max;
}
Sample Output
Enter 5 Numbers:
12 45 18 90 27
Largest = 90

#include <stdio.h>

int gcd(int a, int b);

int main()
{
    int a, b;

    printf("Enter Two Numbers: ");
    scanf("%d%d", &a, &b);

    printf("GCD = %d", gcd(a, b));

    return 0;
}

int gcd(int a, int b)
{
    int i, gcd = 1;

    for(i = 1; i <= a && i <= b; i++)
    {
        if(a % i == 0 && b % i == 0)
            gcd = i;
    }

    return gcd;
}
Sample Output
Enter Two Numbers: 24 36
GCD = 12

#include <stdio.h>

void checkEvenOdd(int n);

int main()
{
    int num;

    printf("Enter Number: ");
    scanf("%d", &num);

    checkEvenOdd(num);

    return 0;
}

void checkEvenOdd(int n)
{
    if(n % 2 == 0)
        printf("Even Number");
    else
        printf("Odd Number");
}

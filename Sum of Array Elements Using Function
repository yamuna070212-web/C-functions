#include <stdio.h>

int arraySum(int arr[], int n);

int main()
{
    int arr[5], i;

    printf("Enter 5 Elements:\n");

    for(i = 0; i < 5; i++)
        scanf("%d", &arr[i]);

    printf("Sum = %d", arraySum(arr, 5));

    return 0;
}

int arraySum(int arr[], int n)
{
    int i, sum = 0;

    for(i = 0; i < n; i++)
        sum += arr[i];

    return sum;
}
